{
  "name": "dungeonplanner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "vite",
    "dev:full": "turbo run dev --parallel --filter=dungeonplanner --filter=dungeonplanner-server",
    "build": "pnpm run build:demo && pnpm run build:docs",
    "build:demo": "tsc -b && vite build",
    "build:docs": "node scripts/build-docs-site.mjs",
    "build:all": "turbo run build",
    "docs:build": "pnpm run build:docs",
    "lint": "eslint .",
    "lint:all": "turbo run lint",
    "preview": "vite preview",
    "generate:content-pack:core": "node scripts/generate-core-pack.mjs",
    "generate:thumbnails": "node scripts/generate-thumbnails.mjs",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "verify": "pnpm run lint && pnpm run test && pnpm run build && pnpm run test:e2e",
    "server": "pnpm --filter dungeonplanner-server dev",
    "server:build": "pnpm --filter dungeonplanner-server build",
    "server:start": "pnpm --filter dungeonplanner-server start",
    "turbo": "turbo"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "three": "^0.182.0",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "gltfjsx": "^6.5.3",
    "jsdom": "^29.0.2",
    "turbo": "^2.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
